# ========================
# FaceSentrix - .gitignore
# ========================

# ---- Core Documentation ----
# Keep docs/ for tracking TODO.md and architecture
!docs/
!docs/*.md

# ---- Python environments & dev ----
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env.bak/
venv.bak/

# ---- Secrets ----
.env
.env.local

# ---- IDEs & Editors ----
.vscode/
.idea/
*.swp
*.swo

# ---- Data & Models (Binary Files) ----
data/raw/
data/processed/*.npy
models/*.h5
models/*.tflite
models/*.pkl
models/training_log.csv

# ---- Logs & Temporary ----
logs/
*.log
.DS_Store
Thumbs.db
